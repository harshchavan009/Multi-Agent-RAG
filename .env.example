# ============================================================
# Enterprise Agentic RAG — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=enterprise_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://postgres:change_me_strong_password@localhost:5432/enterprise_rag
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_password@localhost:5432/enterprise_rag

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# ── JWT ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_256_BIT_RANDOM_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── SMTP (Email) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@enterprise-rag.ai

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
